{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Poke One-to-One Recipe Schema",
  "type": "object",
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "trigger": {
          "type": "object",
          "properties": {
            "type": { "enum": ["manual", "webhook", "schedule"] },
            "condition": { "type": "string" }
          },
          "required": ["type"]
        }
      },
      "required": ["name"]
    },
    "parameters": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "default": {}
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "tool": { "type": "string" },
          "args": { "type": "object" },
          "condition": { "type": "string" }
        },
        "required": ["tool", "args"]
      }
    }
  },
  "required": ["metadata", "steps"]
}
